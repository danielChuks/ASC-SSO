# Sepolia config (for npm run deploy:dao:sepolia)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Or: https://sepolia.infura.io/v3/YOUR_KEY

# Private key: 0x + 64 hex chars. Export from MetaMask (Account details → Show private key).
# NOT the address (40 chars) — that will fail with "private key too short"
SEPOLIA_DEPLOYER_PRIVATE_KEY=0x...

# Address that will relay votes (e.g. deployer address, or backend relayer address)
DAO_VOTE_RELAYER_ADDRESS=0x...


