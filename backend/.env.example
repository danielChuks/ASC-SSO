# Required
DATABASE_URL=postgresql://user:password@localhost:5432/shieldlogin

# Required for IdR (commitments): On-chain Solidity CommitmentRegistry
IDR_CONTRACT_ADDRESS=0x...
ETH_RPC_URL=http://127.0.0.1:8545
IDR_DEPLOYER_KEY=0x...  # Private key for addCommitment (write) transactions

# DAO Voting (optional): On-chain DAOVoting contract
DAO_VOTING_CONTRACT_ADDRESS=0x...
DAO_VOTE_RELAYER_ADDRESS=0x...  # Address configured as voteRelayer in DAOVoting constructor
DAO_VOTE_RELAYER=0x...  # Private key for vote relayer (castVote)
